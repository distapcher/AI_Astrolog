BOT_TOKEN=your_telegram_bot_token

# RapidAPI — Astrologer API (Kerykeion backend, SVG-чарт)
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=astrologer.p.rapidapi.com

# Полная ИИ-расшифровка по 10 разделам (DeepSeek / OpenAI-совместимый API)
OPENAI_API_KEY=your_deepseek_api_key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# GeoNames для Kerykeion online-режима (если не используем Nominatim)
# GEONAMES_USERNAME=

CHART_THEME=dark
CHART_LANGUAGE=RU
